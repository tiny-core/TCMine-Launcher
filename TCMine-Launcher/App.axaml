<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TCMine_Launcher.App"
             xmlns:local="using:TCMine_Launcher"
             xmlns:conv="using:TCMine_Launcher.Converters"
             RequestedThemeVariant="Default">
    <!-- "Default" ThemeVariant follows the system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Resources>
        <ResourceDictionary>
            <conv:StringToBrushConverter x:Key="StringToBrush" />
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Themes/Palette.axaml" />
                <ResourceInclude Source="/Themes/Icons.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="/Themes/Styles/Text.axaml" />
        <StyleInclude Source="/Themes/Styles/Buttons.axaml" />
        <StyleInclude Source="/Themes/Styles/Cards.axaml" />
        <StyleInclude Source="/Themes/Styles/Controls.axaml" />
    </Application.Styles>
</Application>
