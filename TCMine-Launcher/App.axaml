<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TCMine_Launcher.App"
             xmlns:local="using:TCMine_Launcher"
             RequestedThemeVariant="Default">
    <!-- "Default" ThemeVariant follows the system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />

        <!-- ======================================================= -->
        <!--  BOTÕES DA BARRA DE TÍTULO  (fechar / minimizar)        -->
        <!-- ======================================================= -->
        <Style Selector="Button.wnd-btn">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="40" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#2A2A40" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="Button.wnd-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1A1A2E" />
        </Style>
        <Style Selector="Button.wnd-btn:pointerover">
            <Setter Property="Foreground" Value="#64648A" />
        </Style>
        <!-- Botão fechar fica vermelho no hover -->
        <Style Selector="Button.wnd-btn-close:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#7F1D1D" />
        </Style>
        <Style Selector="Button.wnd-btn-close:pointerover">
            <Setter Property="Foreground" Value="#FCA5A5" />
        </Style>

        <!-- ======================================================= -->
        <!--  BOTÕES DE NAVEGAÇÃO DA SIDEBAR                         -->
        <!-- ======================================================= -->
        <Style Selector="Button.nav-btn">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#343454" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="Button.nav-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#141422" />
        </Style>
        <Style Selector="Button.nav-btn:pointerover">
            <Setter Property="Foreground" Value="#64648A" />
        </Style>
        <!-- Estado activo (página atual) -->
        <Style Selector="Button.nav-btn.active /template/ ContentPresenter">
            <Setter Property="Background" Value="#1A0E20" />
        </Style>
        <Style Selector="Button.nav-btn.active">
            <Setter Property="Foreground" Value="#F97316" />
        </Style>
        <Style Selector="Button.nav-btn.active:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1A0E20" />
        </Style>

        <!-- ======================================================= -->
        <!--  SELETORES DE VERSÃO (ComboBox)                         -->
        <!-- ======================================================= -->
        <Style Selector="ComboBox.version-select">
            <Setter Property="Background" Value="#0A0A16" />
            <Setter Property="BorderBrush" Value="#1A1A28" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Foreground" Value="#7A7A9A" />
            <Setter Property="Padding" Value="11,8" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="MaxDropDownHeight" Value="200" />
        </Style>
        <Style Selector="ComboBox.version-select:pointerover">
            <Setter Property="BorderBrush" Value="#2A2A40" />
            <Setter Property="Foreground" Value="#94A3B8" />
        </Style>
        <Style Selector="ComboBox.version-select:focus">
            <Setter Property="BorderBrush" Value="#F97316" />
        </Style>

        <!-- ======================================================= -->
        <!--  BOTÃO JOGAR                                            -->
        <!-- ======================================================= -->
        <Style Selector="Button.play-btn">
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                        <GradientStop Color="#F97316" Offset="0" />
                        <GradientStop Color="#DC5808" Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>
        <Style Selector="Button.play-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.88" />
        </Style>
        <Style Selector="Button.play-btn:pressed /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.75" />
        </Style>
        <Style Selector="Button.play-btn:disabled">
            <Setter Property="Opacity" Value="0.45" />
        </Style>

        <!-- ======================================================= -->
        <!--  BARRA DE PROGRESSO DO LAUNCH                           -->
        <!-- ======================================================= -->
        <Style Selector="ProgressBar.launch-progress">
            <Setter Property="Background" Value="#12121E" />
            <Setter Property="Foreground" Value="#F97316" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Height" Value="4" />
        </Style>

        <!-- ======================================================= -->
        <!--  CARTÃO CENTRAL                                         -->
        <!-- ======================================================= -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#0E0E1A" />
            <Setter Property="BorderBrush" Value="#1A1A2A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="34,30" />
            <Setter Property="Width" Value="360" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- ======================================================= -->
        <!--  ETIQUETAS DE SECÇÃO (VERSÃO MINECRAFT / NEOFORGE)      -->
        <!-- ======================================================= -->
        <Style Selector="TextBlock.section-label">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#4A4A66" />
            <Setter Property="LetterSpacing" Value="1.5" />
            <Setter Property="Margin" Value="2,0,0,7" />
        </Style>

        <!-- ======================================================= -->
        <!--  AVATAR DO JOGADOR (círculo com gradiente laranja)      -->
        <!--  Tamanho definido inline (Width/Height) em cada uso.    -->
        <!-- ======================================================= -->
        <Style Selector="Border.avatar">
            <Setter Property="CornerRadius" Value="1000" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="#F97316" Offset="0" />
                        <GradientStop Color="#C2410C" Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>
        <Style Selector="Border.avatar > TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- ======================================================= -->
        <!--  PAINEL GENÉRICO                                        -->
        <!-- ======================================================= -->
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="#0E0E1A" />
            <Setter Property="BorderBrush" Value="#1A1A2A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="22" />
        </Style>

        <!-- ======================================================= -->
        <!--  TÍTULO DE PÁGINA / TEXTOS                               -->
        <!-- ======================================================= -->
        <Style Selector="TextBlock.page-title">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#E8E8F0" />
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="#5A5A7A" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <!-- ======================================================= -->
        <!--  BADGE / TAG                                            -->
        <!-- ======================================================= -->
        <Style Selector="Border.tag">
            <Setter Property="Background" Value="#2A1206" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <Style Selector="Border.tag > TextBlock">
            <Setter Property="Foreground" Value="#F97316" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LetterSpacing" Value="1" />
        </Style>

        <!-- ======================================================= -->
        <!--  CHIP DE CONTA (avatar + nome) — clicável               -->
        <!-- ======================================================= -->
        <Style Selector="Button.account-chip">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="6" />
        </Style>
        <Style Selector="Button.account-chip:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#141422" />
        </Style>

        <!-- ======================================================= -->
        <!--  BOTÃO MICROSOFT (login)                                -->
        <!-- ======================================================= -->
        <Style Selector="Button.ms-btn">
            <Setter Property="Background" Value="#14141F" />
            <Setter Property="BorderBrush" Value="#26263A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Foreground" Value="#E8E8F0" />
            <Setter Property="Height" Value="48" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.ms-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1B1B2A" />
            <Setter Property="BorderBrush" Value="#34344E" />
        </Style>

        <!-- ======================================================= -->
        <!--  BOTÃO FANTASMA / SECUNDÁRIO                             -->
        <!-- ======================================================= -->
        <Style Selector="Button.ghost-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#6A6A8A" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
        <Style Selector="Button.ghost-btn:pointerover">
            <Setter Property="Foreground" Value="#A0A0C0" />
        </Style>
        <Style Selector="Button.ghost-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <!-- ======================================================= -->
        <!--  BOTÃO DE ACÇÃO PEQUENO (instalar / sair)               -->
        <!-- ======================================================= -->
        <Style Selector="Button.outline-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#2A2A40" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Foreground" Value="#94A3B8" />
            <Setter Property="Padding" Value="14,8" />
        </Style>
        <Style Selector="Button.outline-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#15151F" />
            <Setter Property="BorderBrush" Value="#F97316" />
        </Style>

        <!-- ======================================================= -->
        <!--  CARTÃO DE MODPACK                                      -->
        <!-- ======================================================= -->
        <Style Selector="Border.modpack-card">
            <Setter Property="Background" Value="#0E0E1A" />
            <Setter Property="BorderBrush" Value="#1A1A2A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Width" Value="240" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.modpack-card:pointerover">
            <Setter Property="BorderBrush" Value="#3A2A1A" />
        </Style>
    </Application.Styles>
</Application>