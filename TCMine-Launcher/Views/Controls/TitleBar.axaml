<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="600"
             x:Class="TCMine_Launcher.Views.TitleBar"
             x:Name="Root"
             x:CompileBindings="False">

    <!-- Barra de título reutilizável (janela sem chrome nativo). Resolve a
         janela-pai via TopLevel — arrastar, minimizar e fechar. -->
    <Border Background="Transparent"
            BorderBrush="{StaticResource BorderChrome}"
            BorderThickness="0,0,0,1"
            PointerPressed="OnDrag">
        <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="11"
                        VerticalAlignment="Center" Margin="20,0,0,0">
                <Image Source="{StaticResource AppLogo}" Width="20" Height="20" VerticalAlignment="Center" />
                <TextBlock Text="{Binding #Root.Title}" FontSize="12.5"
                           Foreground="#3A3A52" VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Classes="wnd-btn" Click="OnMinimize"
                        IsVisible="{Binding #Root.ShowMinimize}">
                    <PathIcon Data="{StaticResource IconMinimize}" Width="13" Height="13" />
                </Button>
                <Button Classes="wnd-btn wnd-btn-close" Click="OnClose">
                    <PathIcon Data="{StaticResource IconClose}" Width="13" Height="13" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>