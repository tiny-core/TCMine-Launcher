<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:m="using:TCMine_Launcher.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="540"
             x:Class="TCMine_Launcher.Views.ServerEntryRow"
             x:Name="RowRoot"
             x:DataType="m:ServerEntry">

    <!-- Linha de um servidor configurado (nome + ip + remover). DataContext =
         ServerEntry; o comando de remover vem do ViewModel passado em Owner. -->
    <Grid ColumnDefinitions="*,Auto" Margin="0,3" Background="Transparent">
        <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
            <TextBlock Text="{Binding Name}" FontSize="12.5" Foreground="{StaticResource TextPrimary}" />
            <TextBlock Text="{Binding Ip}" FontSize="11" Foreground="{StaticResource TextMuted}" />
        </StackPanel>
        <Button Grid.Column="1" Classes="ghost-btn"
                Command="{Binding #RowRoot.Owner.RemoveServerCommand}"
                CommandParameter="{Binding}">
            <PathIcon Data="{StaticResource IconClose}" Width="12" Height="12"
                      Foreground="{StaticResource Danger}" />
        </Button>
    </Grid>
</UserControl>
