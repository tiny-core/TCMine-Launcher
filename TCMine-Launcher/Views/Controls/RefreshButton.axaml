<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="120"
             x:Class="TCMine_Launcher.Views.RefreshButton"
             x:Name="Root"
             x:CompileBindings="False">

    <!-- Botão "Atualizar" com spinner. Liga-se a Command + IsLoading. -->
    <Button Classes="outline-btn" 
            VerticalAlignment="Center"
            Command="{Binding #Root.Command}"
            IsEnabled="{Binding !#Root.IsLoading}">
        <Panel>
            <StackPanel Orientation="Horizontal"
                        Spacing="6" IsVisible="{Binding !#Root.IsLoading}">
                <PathIcon Data="{StaticResource IconRefresh}"
                          Width="14" 
                          Height="14" 
                          VerticalAlignment="Center" />
                <TextBlock Text="Atualizar"
                           FontSize="12.5"
                           VerticalAlignment="Center" />
            </StackPanel>
            <Ellipse Classes="spinner"
                     Width="14"
                     Height="14"
                     IsVisible="{Binding #Root.IsLoading}" />
        </Panel>
    </Button>
</UserControl>