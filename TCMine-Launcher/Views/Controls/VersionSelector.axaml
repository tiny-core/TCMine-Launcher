<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="280"
             x:Class="TCMine_Launcher.Views.VersionSelector"
             x:Name="Root"
             x:CompileBindings="False">

    <!-- Seletor de versão reutilizável: etiqueta + spinner (enquanto carrega) +
         ComboBox. Totalmente desacoplado do ViewModel — liga-se por propriedades. -->
    <StackPanel>
        <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" 
                       Classes="section-label" 
                       Text="{Binding #Root.Label}" />
            <Ellipse Grid.Column="1"
                     Classes="spinner"
                     Width="12"
                     Height="12"
                     Margin="0,0,4,6" 
                     IsVisible="{Binding #Root.IsLoading}" />
        </Grid>
        <ComboBox Classes="version-select"
                  ItemsSource="{Binding #Root.ItemsSource}"
                  SelectedItem="{Binding #Root.SelectedItem, Mode=TwoWay}" />
    </StackPanel>
</UserControl>