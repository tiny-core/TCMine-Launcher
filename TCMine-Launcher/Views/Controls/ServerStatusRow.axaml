<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TCMine_Launcher.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="260"
             x:Class="TCMine_Launcher.Views.ServerStatusRow"
             x:DataType="vm:ServerStatusItem">

    <!-- Linha de estado de um servidor (online/offline + jogadores + MOTD). -->
    <StackPanel Spacing="4" Margin="12,9">
        <Grid ColumnDefinitions="*,Auto,Auto" VerticalAlignment="Center">
            <TextBlock Grid.Column="0" Text="{Binding Name}"
                       FontSize="12.5" Foreground="{StaticResource TextPrimary}"
                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                         Fill="{Binding StatusColor, Converter={StaticResource StringToBrush}}" />
                <TextBlock Text="{Binding StatusText}" FontSize="11"
                           Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Toggle compacto: entrar neste servidor ao iniciar (rádio). -->
            <Button Grid.Column="2" Classes="autojoin-mini" Classes.active="{Binding IsAutoJoin}"
                    Command="{Binding ToggleAutoJoinCommand}" Margin="6,0,0,0"
                    ToolTip.Tip="{Binding AutoJoinLabel}">
                <PathIcon Data="{StaticResource IconPlay}" Width="10" Height="10"
                          VerticalAlignment="Center" />
            </Button>
        </Grid>

        <Separator Classes="divider" Margin="0, 5" />

        <TextBlock Text="{Binding Motd}" FontSize="10.5" Foreground="{StaticResource TextDim}"
                   TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center"
                   IsVisible="{Binding Motd, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
    </StackPanel>
</UserControl>