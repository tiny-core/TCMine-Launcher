<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TCMine_Launcher.ViewModels"
        xmlns:views="using:TCMine_Launcher.Views"
        xmlns:bh="using:TCMine_Launcher.Behaviors"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="640"
        x:Class="TCMine_Launcher.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/icon.ico"
        Title="TCMine Launcher"
        Width="1100" Height="640"
        WindowStartupLocation="CenterScreen"
        WindowDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!--  RAIZ — cantos arredondados sobre fundo transparente    -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <views:WindowChrome>
        <Grid RowDefinitions="Auto,*,42">

            <!-- ═══════════════════════════════════════════════════ -->
            <!--  BARRA DE TÍTULO (componente reutilizável)          -->
            <!-- ═══════════════════════════════════════════════════ -->
            <views:TitleBar Grid.Row="0" Title="TCMine Launcher" ShowAbout="True" />

            <!-- ═══════════════════════════════════════════════════ -->
            <!--  CORPO — Login (deslogado) OU Shell (logado)        -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Panel Grid.Row="1">

                <!-- ── TELA DE LOGIN ─────────────────────────────── -->
                <views:LoginView IsVisible="{Binding !IsLoggedIn}" />

                <!-- ── APLICAÇÃO (sidebar + página activa) ───────── -->
                <Grid IsVisible="{Binding IsLoggedIn}" ColumnDefinitions="64,*">

                    <!-- SIDEBAR -->
                    <Border Grid.Column="0"
                            Background="{StaticResource BgSidebar}"
                            BorderBrush="{StaticResource BorderChrome}"
                            BorderThickness="0,0,1,0">
                        <Grid RowDefinitions="*,Auto">
                            <StackPanel Grid.Row="0"
                                        Margin="0,8,0,0"
                                        Spacing="6"
                                        HorizontalAlignment="Center">
                                <Button Classes="nav-btn"
                                        Classes.active="{Binding IsHomeSelected}"
                                        Command="{Binding NavigateCommand}"
                                        CommandParameter="{x:Static vm:AppTab.Home}"
                                        ToolTip.Tip="Jogar">
                                    <PathIcon Data="{StaticResource IconPlay}" Width="18" Height="18" />
                                </Button>
                                <Button Classes="nav-btn"
                                        Classes.active="{Binding IsInstancesSelected}"
                                        Command="{Binding NavigateCommand}"
                                        CommandParameter="{x:Static vm:AppTab.Instances}"
                                        ToolTip.Tip="Instâncias">
                                    <PathIcon Data="{StaticResource IconInstances}" Width="18" Height="18" />
                                </Button>
                                <Button Classes="nav-btn"
                                        Classes.active="{Binding IsModpacksSelected}"
                                        Command="{Binding NavigateCommand}"
                                        CommandParameter="{x:Static vm:AppTab.Modpacks}"
                                        ToolTip.Tip="Modpacks">
                                    <PathIcon Data="{StaticResource IconModpacks}" Width="18" Height="18" />
                                </Button>
                                <Button Classes="nav-btn"
                                        Classes.active="{Binding IsNewsSelected}"
                                        Command="{Binding NavigateCommand}"
                                        CommandParameter="{x:Static vm:AppTab.News}"
                                        ToolTip.Tip="Novidades">
                                    <PathIcon Data="{StaticResource IconNews}" Width="18" Height="18" />
                                </Button>
                            </StackPanel>

                            <StackPanel Grid.Row="1"
                                        Margin="0,0,0,12"
                                        Spacing="10"
                                        HorizontalAlignment="Center">
                                <!-- Chip da conta (avatar) → Definições -->
                                <Button Classes="account-chip"
                                        Command="{Binding NavigateCommand}"
                                        CommandParameter="{x:Static vm:AppTab.Settings}"
                                        ToolTip.Tip="{Binding PlayerName}">
                                    <Border Classes="avatar" Width="34" Height="34" ClipToBounds="True">
                                        <Panel>
                                            <TextBlock Text="{Binding AvatarInitials}" FontSize="13"
                                                       Foreground="White" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            <Image bh:ImageLoader.SourceUrl="{Binding PlayerHeadUrl}"
                                                   Stretch="UniformToFill" />
                                        </Panel>
                                    </Border>
                                </Button>

                                <Button Classes="nav-btn"
                                        Classes.active="{Binding IsSettingsSelected}"
                                        Command="{Binding NavigateCommand}"
                                        CommandParameter="{x:Static vm:AppTab.Settings}"
                                        ToolTip.Tip="Definições">
                                    <PathIcon Data="{StaticResource IconSettings}" Width="18" Height="18" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- PÁGINA ACTIVA (resolvida pelo ViewLocator) -->
                    <TransitioningContentControl Grid.Column="1" Content="{Binding CurrentPage}">
                        <TransitioningContentControl.PageTransition>
                            <CrossFade Duration="0:0:0.18" />
                        </TransitioningContentControl.PageTransition>
                    </TransitioningContentControl>
                </Grid>
            </Panel>

            <!-- ═══════════════════════════════════════════════════ -->
            <!--  BARRA DE ESTADO                                    -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Border Grid.Row="2"
                    Background="{StaticResource BgConsole}"
                    BorderBrush="{StaticResource BorderChrome}"
                    BorderThickness="0,1,0,0">
                <Grid ColumnDefinitions="Auto,*,Auto,14,Auto,14,Auto,14,Auto" Margin="16,0">
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="7"
                                VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7"
                                 Fill="{StaticResource Success}"
                                 IsVisible="{Binding IsLoggedIn}" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="11" Foreground="{StaticResource TextFaint}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Registo de eventos do launch -->
                    <Button Grid.Column="2" Classes="subtle"
                            VerticalAlignment="Center"
                            IsVisible="{Binding IsLoggedIn}"
                            Command="{Binding OpenLogCommand}"
                            ToolTip.Tip="Abrir o registo de eventos">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource IconNews}" Width="12" Height="12"
                                      VerticalAlignment="Center" />
                            <TextBlock Text="Eventos" FontSize="11" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Memória RAM alocada à instância ativa (abre janela com slider) -->
                    <Button Grid.Column="4" Classes="subtle"
                            VerticalAlignment="Center"
                            IsVisible="{Binding IsLoggedIn}"
                            Command="{Binding OpenMemoryCommand}"
                            ToolTip.Tip="Configurar a memória do jogo">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource IconMemory}" Width="12" Height="12"
                                      VerticalAlignment="Center" />
                            <TextBlock Text="{Binding RamDisplay}" FontSize="11" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Aviso de atualização do launcher -->
                    <Button Grid.Column="6" Classes="update-pill"
                            VerticalAlignment="Center"
                            IsVisible="{Binding UpdateAvailable}"
                            Command="{Binding OpenUpdateCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource IconUpload}" Width="11" Height="11"
                                      VerticalAlignment="Center" />
                            <TextBlock Text="{Binding LatestVersion, StringFormat='Atualizar para {0}'}"
                                       FontSize="10.5" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <TextBlock Grid.Column="8"
                               Text="{Binding VersionLabel}"
                               FontSize="11" Foreground="#2A2A40"
                               VerticalAlignment="Center"
                               ToolTip.Tip="Versão instalada do launcher" />
                </Grid>
            </Border>
        </Grid>
    </views:WindowChrome>
</Window>