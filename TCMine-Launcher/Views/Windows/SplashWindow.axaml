<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:TCMine_Launcher.Views"
        x:Class="TCMine_Launcher.Views.SplashWindow"
        Width="600" Height="300"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        WindowDecorations="None"
        Topmost="True"
        ShowInTaskbar="False"
        Background="Transparent"
        TransparencyLevelHint="Transparent">

    <views:WindowChrome>
        <views:WindowChrome.Background>
            <RadialGradientBrush Center="50%,0%"
                                 GradientOrigin="50%,0%"
                                 RadiusX="80%"
                                 RadiusY="80%">
                <GradientStop Color="#161018"
                              Offset="0" />
                <GradientStop Color="#0B0B14"
                              Offset="1" />
            </RadialGradientBrush>
        </views:WindowChrome.Background>

        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center" 
                    Spacing="14">
            <Image Source="{StaticResource AppLogo}"
                   Width="64" 
                   Height="64"
                   HorizontalAlignment="Center" />
            <TextBlock Text="TCMine Launcher" 
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}"
                       HorizontalAlignment="Center" />
            <StackPanel Orientation="Horizontal"
                        Spacing="10" 
                        HorizontalAlignment="Center"
                        Margin="0,6,0,0">
                <Ellipse Classes="spinner"
                         Width="16" Height="16" />
                <TextBlock Text="A iniciar..."
                           Classes="muted" 
                           VerticalAlignment="Center" />
            </StackPanel>
        </StackPanel>
    </views:WindowChrome>
</Window>