<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TCMine_Launcher.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="940" d:DesignHeight="555"
             x:Class="TCMine_Launcher.Views.HomePageView"
             x:DataType="vm:HomePageViewModel">

    <Grid Margin="26" ColumnDefinitions="*,18,300">

        <!-- ════════════════════════════════════════════════════ -->
        <!--  ESQUERDA: hero do modpack + barra de launch          -->
        <!-- ════════════════════════════════════════════════════ -->
        <Grid Grid.Column="0" RowDefinitions="*,Auto,Auto">

            <!-- Hero / banner -->
            <Border Grid.Row="0" CornerRadius="16" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="#3B1D4D" Offset="0" />
                        <GradientStop Color="#1A1326" Offset="0.55" />
                        <GradientStop Color="#2A1206" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <!-- brilho decorativo -->
                    <Border>
                        <Border.Background>
                            <RadialGradientBrush Center="85%,15%" GradientOrigin="85%,15%"
                                                 RadiusX="50%" RadiusY="60%">
                                <GradientStop Color="#40F97316" Offset="0" />
                                <GradientStop Color="#00F97316" Offset="1" />
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>

                    <StackPanel VerticalAlignment="Bottom" Margin="30,0,30,28" Spacing="0">
                        <Border Classes="tag">
                            <TextBlock Text="{Binding InstanceTag}" />
                        </Border>
                        <TextBlock Text="{Binding InstanceName}"
                                   FontSize="34" FontWeight="Bold" Foreground="White"
                                   Margin="0,12,0,0" />
                        <TextBlock Text="{Binding InstanceSubtitle}"
                                   FontSize="13" Foreground="#C9B8D8" Margin="0,2,0,0" />
                        <TextBlock Text="{Binding InstanceSummary}"
                                   FontSize="13" Foreground="#9A8AA8"
                                   TextWrapping="Wrap" MaxWidth="460"
                                   HorizontalAlignment="Left"
                                   Margin="0,12,0,0" />
                    </StackPanel>

                    <!-- Overlay de loading (spinner reutilizável) -->
                    <Border Classes="busy-overlay" IsVisible="{Binding IsLaunching}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Spacing="16">
                            <Ellipse Classes="spinner" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding LaunchStatus}"
                                       Foreground="#E8E8F0" FontSize="14"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding LaunchProgress, StringFormat='{}{0:0}%'}"
                                       Foreground="#F97316" FontSize="13" FontWeight="Bold"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Barra de launch -->
            <StackPanel Grid.Row="1" Margin="0,18,0,0" Spacing="12">
                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="9"
                                VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="#22C55E"
                                 IsVisible="{Binding !IsLaunching}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding LaunchStatus}"
                                   Foreground="#8A8AAA" FontSize="13"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Classes="play-btn"
                            Command="{Binding PlayCommand}"
                            Width="230" Height="50">
                        <StackPanel Orientation="Horizontal" Spacing="10"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="{Binding PlayIcon}" FontSize="13" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding PlayLabel}" FontSize="14" FontWeight="Bold"
                                       LetterSpacing="2" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>

            <!-- Registo / console do launch (colapsável) -->
            <StackPanel Grid.Row="2" Margin="0,12,0,0" Spacing="8">
                <ToggleButton Classes="log-toggle"
                              HorizontalAlignment="Left"
                              IsChecked="{Binding IsLogExpanded}"
                              Content="{Binding LogToggleLabel}" />
                <Border Classes="log-panel" IsVisible="{Binding IsLogExpanded}">
                    <ScrollViewer Height="130"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding LaunchLog}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </Grid>

        <!-- ════════════════════════════════════════════════════ -->
        <!--  DIREITA: painel de perfil + configuração             -->
        <!-- ════════════════════════════════════════════════════ -->
        <Border Grid.Column="2" Classes="panel">
            <StackPanel Spacing="0">

                <!-- Avatar realocado para aqui -->
                <Border Classes="avatar" Width="72" Height="72">
                    <TextBlock Text="{Binding AvatarInitials}" FontSize="24" />
                </Border>
                <TextBlock Text="{Binding PlayerName}"
                           FontSize="16" FontWeight="Bold" Foreground="#E8E8F0"
                           HorizontalAlignment="Center" Margin="0,12,0,0" />
                <TextBlock Text="{Binding AccountLabel}"
                           Classes="muted" FontSize="11"
                           HorizontalAlignment="Center" Margin="0,3,0,0" />

                <Grid ColumnDefinitions="*,Auto" Margin="2,8,2,0">
                    <TextBlock Grid.Column="0" Classes="section-label" Text="IDENTIFICADOR" Margin="0" />
                    <TextBlock Grid.Column="1" Text="{Binding PlayerUuidShort}"
                               FontFamily="Cascadia Code,Consolas,monospace"
                               FontSize="11" Foreground="#94A3B8" />
                </Grid>

                <Border Height="1" Background="#16161F" Margin="0,20" />

                <!-- Slider de memória da instância -->
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Classes="section-label" Text="MEMÓRIA" Margin="0" />
                    <TextBlock Grid.Column="1" Text="{Binding RamDisplay}"
                               FontSize="11" FontWeight="SemiBold" Foreground="#F97316" />
                </Grid>
                <Slider Minimum="1024" Maximum="16384"
                        TickFrequency="512" IsSnapToTickEnabled="True"
                        Value="{Binding InstanceRam}"
                        IsEnabled="{Binding !IsLaunching}"
                        Margin="0,2,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
