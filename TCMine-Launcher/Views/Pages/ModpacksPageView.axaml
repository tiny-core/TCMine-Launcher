<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TCMine_Launcher.ViewModels"
             xmlns:ctl="using:TCMine_Launcher.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="940" d:DesignHeight="555"
             x:Class="TCMine_Launcher.Views.ModpacksPageView"
             x:DataType="vm:ModpacksPageViewModel"
             x:Name="PageRoot">

    <Grid Margin="26" 
          RowDefinitions="Auto,16,Auto,*">

        <!-- Cabeçalho -->
        <Grid Grid.Row="0" 
              ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0">
                <TextBlock Classes="page-title" 
                           Text="Modpacks oficiais" />
                <TextBlock Classes="muted" 
                           Text="Modpacks publicados pelo servidor TCMine"
                           Margin="0,4,0,0" />
            </StackPanel>
            <ctl:RefreshButton Grid.Column="1"
                               Command="{Binding RefreshCommand}"
                               IsLoading="{Binding IsLoading}" />
        </Grid>

        <!-- Estado / mensagens -->
        <TextBlock Grid.Row="2" 
                   Text="{Binding StatusMessage}"
                   Classes="muted" 
                   FontSize="12" 
                   TextWrapping="Wrap" Margin="0,12,0,0"
                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

        <!-- Catálogo -->
        <ScrollViewer Grid.Row="3"
                      Margin="0,12,0,0" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Modpacks}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:ModpackListItem">
                        <ctl:ModpackCard Margin="0,0,18,18"
                                         Owner="{Binding #PageRoot.((vm:ModpacksPageViewModel)DataContext)}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>