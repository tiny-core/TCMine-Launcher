<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TCMine_Launcher.ViewModels"
             xmlns:m="using:TCMine_Launcher.Models"
             xmlns:conv="using:TCMine_Launcher.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="940" d:DesignHeight="555"
             x:Class="TCMine_Launcher.Views.InstancesPageView"
             x:DataType="vm:InstancesPageViewModel"
             x:Name="PageRoot">

    <Grid Margin="26" RowDefinitions="Auto,Auto,Auto,*">

        <!-- Cabeçalho -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0">
                <TextBlock Classes="page-title" Text="Instâncias" />
                <TextBlock Classes="muted" Text="As tuas instalações isoladas de Minecraft"
                           Margin="0,4,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10"
                        VerticalAlignment="Center">
                <Button Classes="outline-btn" Height="40"
                        IsEnabled="{Binding CanInteract}"
                        Command="{Binding ImportCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="7" HorizontalAlignment="Center">
                        <PathIcon Data="{StaticResource IconDownload}" Width="14" Height="14" VerticalAlignment="Center" />
                        <TextBlock Text="Importar" FontSize="12.5" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Classes="play-btn" Height="40"
                        IsEnabled="{Binding CanInteract}"
                        Command="{Binding OpenCreateCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="7" Margin="6,0"
                                HorizontalAlignment="Center">
                        <PathIcon Data="{StaticResource IconAdd}" Width="15" Height="15" VerticalAlignment="Center" />
                        <TextBlock Text="Nova instância" FontSize="12.5" FontWeight="Bold" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Progresso de import/export (indeterminado; o zip é atómico) -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12"
                    Margin="0,16,0,0" VerticalAlignment="Center"
                    IsVisible="{Binding IsBusy}">
            <ProgressBar Classes="status-progress" IsIndeterminate="True" Width="220"
                         VerticalAlignment="Center" />
            <TextBlock Text="{Binding BusyStatus}" Classes="muted" VerticalAlignment="Center" />
        </StackPanel>

        <Border Grid.Row="2" Classes="divider" Margin="0,20" />
        <!-- Lista de instâncias -->
        <ScrollViewer Grid.Row="3" Margin="0,18,0,0" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Instances}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="m:MinecraftInstance">
                        <Border Classes="modpack-card" Width="304" Margin="0,0,18,18" Padding="22"
                                BorderThickness="1.5">
                            <Border.BorderBrush>
                                <MultiBinding Converter="{x:Static conv:ActiveBorderConverter.Instance}">
                                    <Binding Path="Id" />
                                    <Binding Path="((vm:InstancesPageViewModel)DataContext).ActiveInstanceId"
                                             ElementName="PageRoot" />
                                </MultiBinding>
                            </Border.BorderBrush>
                            <StackPanel Spacing="0">

                                <!-- Cabeçalho do cartão: ícone + nome + tag -->
                                <Grid ColumnDefinitions="56,14,*">
                                    <Border Grid.Column="0" Classes="avatar" Width="56" Height="56">
                                        <TextBlock Text="{Binding Initial}" FontSize="23" />
                                    </Border>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="6">
                                        <TextBlock Text="{Binding Name}"
                                                   Classes="card-title"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Border Classes="tag">
                                            <TextBlock Text="{Binding SourceLabel}" />
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <Border Classes="divider" Margin="0,18" />

                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding VersionSummary}"
                                               Foreground="{StaticResource TextMuted}" FontSize="12.5"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding ModsLabel}"
                                               Foreground="{StaticResource TextFaint}" FontSize="11"
                                               VerticalAlignment="Center" />
                                </Grid>

                                <!-- Ação principal -->
                                <Button Classes="play-btn" Height="40" Margin="0,16,0,0"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        IsEnabled="{Binding #PageRoot.((vm:InstancesPageViewModel)DataContext).CanInteract}"
                                        Command="{Binding #PageRoot.((vm:InstancesPageViewModel)DataContext).SelectCommand}"
                                        CommandParameter="{Binding}">
                                    <TextBlock Text="Selecionar" FontSize="13" FontWeight="Bold"
                                               VerticalAlignment="Center" />
                                </Button>

                                <!-- Ações secundárias: personalizadas vs oficiais -->
                                <Grid Margin="0,10,0,0">
                                    <!-- Personalizada: gerir mods + eliminar -->
                                    <Grid ColumnDefinitions="*,8,*" IsVisible="{Binding !IsOfficial}">
                                        <Button Grid.Column="0" Classes="outline-btn" Height="34"
                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                IsEnabled="{Binding #PageRoot.((vm:InstancesPageViewModel)DataContext).CanInteract}"
                                                Command="{Binding #PageRoot.((vm:InstancesPageViewModel)DataContext).ManageModsCommand}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="Gerir" FontSize="12" />
                                        </Button>
                                        <Button Grid.Column="2" Classes="outline-btn" Height="34"
                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                IsEnabled="{Binding #PageRoot.((vm:InstancesPageViewModel)DataContext).CanInteract}"
                                                Command="{Binding #PageRoot.((vm:InstancesPageViewModel)DataContext).DeleteCommand}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="Eliminar" FontSize="12"
                                                       Foreground="{StaticResource Danger}" />
                                        </Button>
                                    </Grid>

                                    <!-- Oficial: não editável; só permite criar uma cópia -->
                                    <Button Classes="outline-btn" Height="34"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            IsVisible="{Binding IsOfficial}"
                                            IsEnabled="{Binding #PageRoot.((vm:InstancesPageViewModel)DataContext).CanInteract}"
                                            Command="{Binding #PageRoot.((vm:InstancesPageViewModel)DataContext).DuplicateCommand}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                            <PathIcon Data="{StaticResource IconAdd}" Width="13" Height="13" VerticalAlignment="Center" />
                                            <TextBlock Text="Criar cópia editável" FontSize="12" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <!-- Pasta + Exportar (todas as instâncias) -->
                                <Grid ColumnDefinitions="*,8,*" Margin="0,8,0,0">
                                    <Button Grid.Column="0" Classes="subtle"
                                            HorizontalAlignment="Stretch"
                                            Command="{Binding #PageRoot.((vm:InstancesPageViewModel)DataContext).OpenFolderCommand}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                            <PathIcon Data="{StaticResource IconFolder}" Width="13" Height="13" VerticalAlignment="Center" />
                                            <TextBlock Text="Pasta" FontSize="11.5" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="2" Classes="subtle"
                                            HorizontalAlignment="Stretch"
                                            IsEnabled="{Binding #PageRoot.((vm:InstancesPageViewModel)DataContext).CanInteract}"
                                            Command="{Binding #PageRoot.((vm:InstancesPageViewModel)DataContext).ExportCommand}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                            <PathIcon Data="{StaticResource IconUpload}" Width="13" Height="13" VerticalAlignment="Center" />
                                            <TextBlock Text="Exportar" FontSize="11.5" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>