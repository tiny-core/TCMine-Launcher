<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TCMine_Launcher.ViewModels"
             xmlns:m="using:TCMine_Launcher.Models"
             xmlns:ctl="using:TCMine_Launcher.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="940" d:DesignHeight="555"
             x:Class="TCMine_Launcher.Views.InstanceModsPageView"
             x:DataType="vm:InstanceModsPageViewModel"
             x:Name="PageRoot">


    <StackPanel>
        <!-- Nome + versões -->
        <Border Classes="panel"
                Margin="0, 0,0, 20">
            <StackPanel Spacing="0">
                <TextBlock Classes="section-label"
                           Text="NOME" />
                <TextBox Classes="field"
                         Text="{Binding Name}"
                         Foreground="{StaticResource TextPrimary}" />

                <Grid ColumnDefinitions="*,16,*"
                      Margin="0,16,0,0">
                    <ctl:VersionSelector Grid.Column="0"
                                         Label="VERSÃO MINECRAFT"
                                         ItemsSource="{Binding MinecraftVersions}"
                                         SelectedItem="{Binding SelectedMinecraftVersion}" />
                    <ctl:VersionSelector Grid.Column="2"
                                         Label="NEOFORGE"
                                         ItemsSource="{Binding NeoForgeVersions}"
                                         SelectedItem="{Binding SelectedNeoForgeVersion}"
                                         IsLoading="{Binding IsLoadingNeoForge}" />
                </Grid>

                <TextBlock Classes="section-label"
                           Text="CAMINHO DO JAVA (opcional)"
                           Margin="2,16,0,7" />
                <TextBox Classes="field"
                         Text="{Binding JavaPathOverride}"
                         PlaceholderText="Automático (descarrega o Java correto)" />

                <TextBlock Classes="muted"
                           FontSize="11"
                           Margin="2,10,0,0"
                           Text="Mudar a versão exige reinstalar ao jogar a seguir. Java vazio = automático." />
            </StackPanel>
        </Border>

        <!-- Servidores (geridos numa janela própria, como os mods) -->
        <Border Classes="panel"
                Margin="0,0,0,20">
            <Grid ColumnDefinitions="*,Auto"
                  VerticalAlignment="Center">
                <StackPanel Grid.Column="0"
                            Spacing="2">
                    <TextBlock Classes="section-label"
                               Text="SERVIDORES"
                               Margin="0" />
                    <TextBlock Text="{Binding ServerCount, StringFormat='{}{0} servidor(es)'}"
                               Foreground="{StaticResource TextSecondary}" FontSize="12.5" />
                </StackPanel>
                <Button Grid.Column="1" Classes="outline-btn" Height="38"
                        Command="{Binding OpenServersCommand}">
                    <TextBlock Text="Gerir servidores" FontSize="12.5" />
                </Button>
            </Grid>
        </Border>

        <!-- Mods -->
        <Border Classes="panel"
                Margin="0,0,0,20">
            <Grid ColumnDefinitions="*,Auto"
                  VerticalAlignment="Center">
                <StackPanel Grid.Column="0"
                            Spacing="2">
                    <TextBlock Classes="section-label"
                               Text="MODS"
                               Margin="0" />
                    <TextBlock Text="{Binding ModCount, StringFormat='{}{0} mod(s) instalado(s)'}"
                               Foreground="{StaticResource TextSecondary}" FontSize="12.5" />
                </StackPanel>
                <Button Grid.Column="1"
                        Classes="outline-btn"
                        Height="38"
                        Command="{Binding OpenModsCommand}">
                    <TextBlock Text="Gerir mods" FontSize="12.5" />
                </Button>
            </Grid>
        </Border>

        <StackPanel Orientation="Horizontal"
                    Spacing="12" HorizontalAlignment="Right">
            <Button Classes="play-btn"
                    Height="40"
                    Width="150"
                    HorizontalContentAlignment="Center"
                    Command="{Binding ConcludeCommand}">
                <TextBlock Text="Concluído"
                           FontSize="13"
                           FontWeight="Bold" />
            </Button>
        </StackPanel>
    </StackPanel>

</UserControl>