<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TCMine_Launcher.ViewModels"
             xmlns:m="using:TCMine_Launcher.Models"
             xmlns:ctl="using:TCMine_Launcher.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="940" d:DesignHeight="555"
             x:Class="TCMine_Launcher.Views.NewsPageView"
             x:DataType="vm:NewsPageViewModel">

    <Grid Margin="26, 26, 26,0"
          RowDefinitions="Auto,Auto,16,*">

        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0">
                <TextBlock Classes="page-title"
                           Text="Novidades" />
                <TextBlock Classes="muted"
                           Text="Últimas atualizações do launcher e do modpack"
                           Margin="0,4,0,0" />
            </StackPanel>
            <ctl:RefreshButton Grid.Column="1"
                               Command="{Binding RefreshCommand}"
                               IsLoading="{Binding IsLoading}" />
        </Grid>

        <TextBlock Grid.Row="1"
                   Text="{Binding StatusMessage}"
                   Classes="muted"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,12,0,0"
                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

        <ScrollViewer Grid.Row="3">
            <ItemsControl ItemsSource="{Binding News}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="m:NewsItem">
                        <ctl:NewsCard Margin="0,0,0,12" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>