<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TCMine_Launcher.ViewModels"
             xmlns:m="using:TCMine_Launcher.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="940" d:DesignHeight="555"
             x:Class="TCMine_Launcher.Views.NewsPageView"
             x:DataType="vm:NewsPageViewModel">

    <Grid Margin="26" RowDefinitions="Auto,16,*">

        <StackPanel Grid.Row="0">
            <TextBlock Classes="page-title" Text="Novidades" />
            <TextBlock Classes="muted" Text="Últimas atualizações do launcher e do modpack"
                       Margin="0,4,0,0" />
        </StackPanel>

        <ScrollViewer Grid.Row="2">
            <ItemsControl ItemsSource="{Binding News}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="m:NewsItem">
                        <Border Classes="panel" Margin="0,0,0,12" Padding="20,18">
                            <StackPanel Spacing="0">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <Border Grid.Column="0" Classes="tag">
                                        <TextBlock Text="{Binding Tag}" />
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="{Binding Date}"
                                               Classes="muted" FontSize="11"
                                               VerticalAlignment="Center" />
                                </Grid>
                                <TextBlock Text="{Binding Title}"
                                           FontSize="16" FontWeight="Bold" Foreground="#E8E8F0"
                                           Margin="0,12,0,0" />
                                <TextBlock Text="{Binding Summary}"
                                           Foreground="#7A7A9A" FontSize="13"
                                           TextWrapping="Wrap" Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
