<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TCMine_Launcher.Views.ConfirmDialog"
        Title="Confirmar"
        Width="430" Height="200"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        WindowDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent">

    <Border Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
            CornerRadius="14" Padding="26">
        <DockPanel>
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="12"
                        HorizontalAlignment="Right" Margin="0,22,0,0">
                <Button Classes="ghost-btn" Click="Cancel_Click">
                    <TextBlock Text="Cancelar" FontSize="13" />
                </Button>
                <Button Click="Confirm_Click" Height="38" Width="120"
                        Background="{StaticResource DangerBorder}" Foreground="White" BorderThickness="0"
                        CornerRadius="9" HorizontalContentAlignment="Center">
                    <TextBlock Text="Eliminar" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
                </Button>
            </StackPanel>

            <StackPanel Spacing="10" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" />
                <TextBlock x:Name="MessageText" FontSize="13" Foreground="#9A9ABA"
                           TextWrapping="Wrap" />
            </StackPanel>
        </DockPanel>
    </Border>
</Window>