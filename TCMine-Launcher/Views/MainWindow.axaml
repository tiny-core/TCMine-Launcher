<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TCMine_Launcher.ViewModels"
        xmlns:views="using:TCMine_Launcher.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1040" d:DesignHeight="640"
        x:Class="TCMine_Launcher.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="TCMine Launcher"
        Width="1040" Height="640"
        MinWidth="1000" MinHeight="600"
        WindowDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!--  RAIZ — cantos arredondados sobre fundo transparente    -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <Border Background="#0B0B14"
            CornerRadius="12"
            ClipToBounds="True">
        <Grid RowDefinitions="45,*,28">

            <!-- ═══════════════════════════════════════════════════ -->
            <!--  BARRA DE TÍTULO (arrastável)                       -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Border Grid.Row="0"
                    Background="Transparent"
                    BorderBrush="#141420"
                    BorderThickness="0,0,0,1"
                    PointerPressed="TitleBar_PointerPressed">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="11"
                                VerticalAlignment="Center"
                                Margin="20,0,0,0">
                        <TextBlock Text="⬡" FontSize="17" Foreground="#F97316"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="TCMine Launcher" FontSize="12.5" Foreground="#3A3A52"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Classes="wnd-btn" Click="MinimizeButton_Click">
                            <TextBlock Text="—" FontSize="13"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                        <Button Classes="wnd-btn wnd-btn-close" Click="CloseButton_Click">
                            <TextBlock Text="✕" FontSize="13"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════ -->
            <!--  CORPO — Login (deslogado) OU Shell (logado)        -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Panel Grid.Row="1">

                <!-- ── TELA DE LOGIN ─────────────────────────────── -->
                <views:LoginView IsVisible="{Binding !IsLoggedIn}" />

                <!-- ── APLICAÇÃO (sidebar + página activa) ───────── -->
                <Grid IsVisible="{Binding IsLoggedIn}" ColumnDefinitions="64,*">

                    <!-- SIDEBAR -->
                    <Border Grid.Column="0"
                            Background="#090912"
                            BorderBrush="#141420"
                            BorderThickness="0,0,1,0">
                        <Grid RowDefinitions="*,Auto">
                            <StackPanel Grid.Row="0"
                                        Margin="0,8,0,0"
                                        Spacing="6"
                                        HorizontalAlignment="Center">
                                <Button Classes="nav-btn"
                                        Classes.active="{Binding IsHomeSelected}"
                                        Command="{Binding NavigateCommand}"
                                        CommandParameter="{x:Static vm:AppTab.Home}"
                                        ToolTip.Tip="Jogar">
                                    <TextBlock Text="▶" FontSize="17"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Button>
                                <Button Classes="nav-btn"
                                        Classes.active="{Binding IsModpacksSelected}"
                                        Command="{Binding NavigateCommand}"
                                        CommandParameter="{x:Static vm:AppTab.Modpacks}"
                                        ToolTip.Tip="Modpacks">
                                    <TextBlock Text="⊞" FontSize="17"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Button>
                                <Button Classes="nav-btn"
                                        Classes.active="{Binding IsNewsSelected}"
                                        Command="{Binding NavigateCommand}"
                                        CommandParameter="{x:Static vm:AppTab.News}"
                                        ToolTip.Tip="Novidades">
                                    <TextBlock Text="☰" FontSize="17"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Button>
                            </StackPanel>

                            <StackPanel Grid.Row="1"
                                        Margin="0,0,0,12"
                                        Spacing="10"
                                        HorizontalAlignment="Center">
                                <!-- Chip da conta (avatar) → Definições -->
                                <Button Classes="account-chip"
                                        Command="{Binding NavigateCommand}"
                                        CommandParameter="{x:Static vm:AppTab.Settings}"
                                        ToolTip.Tip="{Binding PlayerName}">
                                    <Border Classes="avatar" Width="34" Height="34">
                                        <TextBlock Text="{Binding AvatarInitials}" FontSize="13" />
                                    </Border>
                                </Button>

                                <Button Classes="nav-btn"
                                        Classes.active="{Binding IsSettingsSelected}"
                                        Command="{Binding NavigateCommand}"
                                        CommandParameter="{x:Static vm:AppTab.Settings}"
                                        ToolTip.Tip="Definições">
                                    <TextBlock Text="⚙" FontSize="17"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- PÁGINA ACTIVA (resolvida pelo ViewLocator) -->
                    <TransitioningContentControl Grid.Column="1" Content="{Binding CurrentPage}">
                        <TransitioningContentControl.PageTransition>
                            <CrossFade Duration="0:0:0.18" />
                        </TransitioningContentControl.PageTransition>
                    </TransitioningContentControl>
                </Grid>
            </Panel>

            <!-- ═══════════════════════════════════════════════════ -->
            <!--  BARRA DE ESTADO                                    -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Border Grid.Row="2"
                    Background="#070710"
                    BorderBrush="#141420"
                    BorderThickness="0,1,0,0">
                <Grid ColumnDefinitions="Auto,*,Auto,16,Auto" Margin="16,0">
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="7"
                                VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7"
                                 Fill="#22C55E"
                                 IsVisible="{Binding IsLoggedIn}" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="11" Foreground="#5A5A7A"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Progresso global (visível durante downloads/launch) -->
                    <ProgressBar Grid.Column="2"
                                 Classes="status-progress"
                                 Value="{Binding GlobalProgress}"
                                 IsVisible="{Binding IsBusy}"
                                 VerticalAlignment="Center" />

                    <TextBlock Grid.Column="4"
                               Text="beta v1"
                               FontSize="11" Foreground="#2A2A40"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
