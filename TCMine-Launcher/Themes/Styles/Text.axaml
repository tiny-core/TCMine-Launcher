<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===================================================================
         TIPOGRAFIA — títulos, etiquetas e textos auxiliares.
         =================================================================== -->

    <!-- ── Título de página ────────────────────────────────────────── -->
    <Style Selector="TextBlock.page-title">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
    </Style>

    <!-- ── Etiqueta de secção (VERSÃO MINECRAFT / NEOFORGE …) ───────── -->
    <Style Selector="TextBlock.section-label">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextLabel}" />
        <Setter Property="LetterSpacing" Value="1.5" />
        <Setter Property="Margin" Value="2,0,0,7" />
    </Style>

    <!-- ── Texto secundário esbatido ───────────────────────────────── -->
    <Style Selector="TextBlock.muted">
        <Setter Property="Foreground" Value="{StaticResource TextFaint}" />
        <Setter Property="FontSize" Value="12" />
    </Style>
</Styles>
