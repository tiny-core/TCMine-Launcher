<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===================================================================
         CARTÕES, PAINÉIS E SUPERFÍCIES.
         =================================================================== -->

    <!-- ── Cartão central ──────────────────────────────────────────── -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{StaticResource BgPanel}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="34,30" />
        <Setter Property="Width" Value="360" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ── Painel genérico ─────────────────────────────────────────── -->
    <Style Selector="Border.panel">
        <Setter Property="Background" Value="{StaticResource BgPanel}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="22" />
    </Style>

    <!-- ── Caixa "inset" (campo/caixa recuada reutilizável) ────────── -->
    <Style Selector="Border.inset">
        <Setter Property="Background" Value="{StaticResource BgInset}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderInset}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <!-- ── Divisória horizontal ────────────────────────────────────── -->
    <Style Selector="Border.divider">
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="{StaticResource BorderDivider}" />
    </Style>

    <!-- ── Cartão de modpack ───────────────────────────────────────── -->
    <Style Selector="Border.modpack-card">
        <Setter Property="Background" Value="{StaticResource BgPanel}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Width" Value="240" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.modpack-card:pointerover">
        <Setter Property="BorderBrush" Value="#3A2A1A" />
    </Style>

    <!-- ── Badge / tag ─────────────────────────────────────────────── -->
    <Style Selector="Border.tag">
        <Setter Property="Background" Value="{StaticResource AccentBg}" />
        <Setter Property="CornerRadius" Value="5" />
        <Setter Property="Padding" Value="8,3" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
    <Style Selector="Border.tag > TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Accent}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LetterSpacing" Value="1" />
    </Style>

    <!-- ── Badge de estado (forma; cor via tokens Success/Warning) ── -->
    <Style Selector="Border.badge">
        <Setter Property="CornerRadius" Value="5" />
        <Setter Property="Padding" Value="7,3" />
    </Style>

    <!-- ── Avatar do jogador (círculo com gradiente laranja) ───────── -->
    <Style Selector="Border.avatar">
        <Setter Property="CornerRadius" Value="1000" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="{StaticResource AccentColor}" Offset="0" />
                    <GradientStop Color="{StaticResource AccentDeepColor}" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>
    <Style Selector="Border.avatar > TextBlock">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ── Overlay de ocupado (loading) ────────────────────────────── -->
    <Style Selector="Border.busy-overlay">
        <Setter Property="Background" Value="#C00B0B14" />
        <Setter Property="CornerRadius" Value="16" />
    </Style>

    <!-- ── Painel de registo (console do launch) ───────────────────── -->
    <Style Selector="Border.log-panel">
        <Setter Property="Background" Value="{StaticResource BgConsole}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderDivider}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,10" />
    </Style>
    <Style Selector="Border.log-panel TextBlock">
        <Setter Property="FontFamily" Value="Cascadia Code,Consolas,monospace" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="Foreground" Value="#7A8A6A" />
    </Style>
</Styles>
