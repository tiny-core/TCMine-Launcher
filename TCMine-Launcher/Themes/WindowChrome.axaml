<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:views="using:TCMine_Launcher.Views">
    <!-- Tema do WindowChrome: borda arredondada + fundo que envolve toda a
         janela (sem chrome nativo). Aplica-se implicitamente por tipo. -->
    <ControlTheme x:Key="{x:Type views:WindowChrome}" TargetType="views:WindowChrome">
        <!-- Fundo e borda têm defaults, mas podem ser substituídos por janela
             (ex.: Splash com gradiente, diálogo com cor de cartão). O raio e a
             espessura são fixos para manter a moldura igual em todas as janelas. -->
        <Setter Property="Background" Value="{StaticResource BgWindow}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        ClipToBounds="True">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      Padding="{TemplateBinding Padding}"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch" />
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>
