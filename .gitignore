# ============================================================
#  .gitignore — C# / .NET + Avalonia UI (desktop)
# ============================================================

# ------ Build & output ------
# (cobre também tudo o que o Avalonia gera: *.g.cs, XAML compilado,
#  source generators — tudo vai parar a obj/ ou bin/)
[Bb]in/
[Oo]bj/
[Oo]ut/
artifacts/
.avalonia/

# ------ Publicação ------
**/publish/
*.pubxml.user

# ------ NuGet ------
*.nupkg
*.snupkg
packages/

# ------ Testes ------
[Tt]est[Rr]esult*/
*.trx
*.coverage*
coverage*/

# ------ IDEs / editores ------
.idea/
.vs/
.vscode/
*.user
*.suo
*.userosscache
*.sln.docstates

# ------ Segredos & config local ------
Client.props
secrets.json
appsettings.local.json
appsettings.*.local.json
*.pfx
*.p12
*.key
.env
.env.*

# ------ Lixo do SO ------
.DS_Store
Thumbs.db
Desktop.ini
